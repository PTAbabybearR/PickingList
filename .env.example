# 复制为 .env 并填写。.env 已被 git 忽略，勿提交真实密钥。

# 数据库（MVP：本地 SQLite）
DATABASE_URL="file:./dev.db"

# 识别提供商与模型（自动识别用）
LLM_PROVIDER="deepseek"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
RECOGNITION_MODEL="deepseek-v4-flash"
# 单次最多识别多少页(控成本)，超出会截断并告警
RECOGNITION_MAX_PAGES="40"

# 本地 PDF 存储根目录（相对项目根）
STORAGE_DIR="./storage"

# 管理员登录（MVP 简化：单管理员凭据）
ADMIN_PASSWORD="changeme"
