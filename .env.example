# 复制为 .env 并填写。.env 已被 git 忽略，勿提交真实密钥。

# 数据库（MVP：本地 SQLite）
DATABASE_URL="file:./dev.db"

# 识别提供商：gemini（推荐，免费额度+视觉）| deepseek（纯文本，不支持图片）
LLM_PROVIDER="gemini"

# Gemini（Google AI Studio，支持视觉/PDF）—— aistudio.google.com 申请 key
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL="gemini-2.5-flash"

# DeepSeek（纯文本，读不了说明书图片，仅备用）
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
RECOGNITION_MODEL="deepseek-v4-flash"

# 单次最多识别多少页(控成本)，超出会截断并告警
RECOGNITION_MAX_PAGES="40"
# 识别渲染倍率与分块(切块避免整页被模型压缩丢失小剪口号)
RECOGNITION_SCALE="6"
RECOGNITION_TILE_COLS="2"
RECOGNITION_TILE_ROWS="2"

# 本地 PDF 存储根目录（相对项目根）
STORAGE_DIR="./storage"

# 管理员登录：存密码哈希（不存明文）。用 `pnpm run hash-password "你的密码"` 生成。
# 下面是默认密码 changeme 的哈希示例，请改成你自己的。
ADMIN_PASSWORD_HASH="8dded5c53de3fbdf7b7c8894f8bd74e9:ed6e607a06492510d3d97b9c4d6ae0418afdb6ec6267287d737bb378b6ba7c68"
# 会话签名密钥（部署时改成随机长串，勿外泄）
AUTH_SECRET="please-change-to-a-random-secret"
