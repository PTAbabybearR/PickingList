# 复制为 .env 并填写。.env 已被 git 忽略，勿提交真实密钥。

# 数据库（MVP：本地 SQLite）
DATABASE_URL="file:./dev.db"

# 识别提供商：gemini（推荐，免费额度+视觉）| deepseek（纯文本，不支持图片）
LLM_PROVIDER="gemini"

# Gemini（Google AI Studio，支持视觉/PDF）—— aistudio.google.com 申请 key
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL="gemini-2.5-flash"

# DeepSeek（纯文本，读不了说明书图片，仅备用）
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
RECOGNITION_MODEL="deepseek-v4-flash"

# 单次最多识别多少页(控成本)，超出会截断并告警
RECOGNITION_MAX_PAGES="40"

# 本地 PDF 存储根目录（相对项目根）
STORAGE_DIR="./storage"

# 管理员登录（MVP 简化：单管理员凭据）
ADMIN_PASSWORD="changeme"
