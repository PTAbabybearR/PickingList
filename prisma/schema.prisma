// PickingList 数据模型 —— 详见 PRD 第四节
// SQLite(本地 MVP)。status 用 String(SQLite 无原生 enum),便于后期平滑迁移 Postgres。

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 等级：HG / RG / MG / PG / SD ...
model Grade {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  series    Series[]
  createdAt DateTime @default(now())
}

// 作品系列：UC / SEED / 水星的魔女 ...（挂在某 Grade 下）
model Series {
  id        String     @id @default(cuid())
  gradeId   String
  grade     Grade      @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int        @default(0)
  modelKits ModelKit[]
  createdAt DateTime   @default(now())

  @@unique([gradeId, name])
  @@index([gradeId])
}

// 具体型号
model ModelKit {
  id        String   @id @default(cuid())
  seriesId  String
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  name      String
  code      String? // 型号编号
  scale     String? // 比例，如 1/144
  boxArtKey String? // 盒绘图在存储适配器中的 key
  status    String   @default("draft") // draft | published | archived
  manuals   Manual[]
  sections  Section[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seriesId])
  @@index([status])
}

// 上传的 PDF 说明书 + 识别状态
model Manual {
  id              String    @id @default(cuid())
  modelKitId      String
  modelKit        ModelKit  @relation(fields: [modelKitId], references: [id], onDelete: Cascade)
  pdfKey          String // 存储适配器中的 key（本地文件路径键）
  pageCount       Int?
  recognizeStatus String    @default("pending") // pending | processing | done | failed
  recognizedAt    DateTime?
  createdAt       DateTime  @default(now())

  @@index([modelKitId])
}

// 部位(Section)：头部 / 胸部 / 手臂 / 腿部 ... —— 取件表以部位为核心组织
model Section {
  id          String        @id @default(cuid())
  modelKitId  String
  modelKit    ModelKit      @relation(fields: [modelKitId], references: [id], onDelete: Cascade)
  name        String // 部位名，如 头 / 胸部
  color       String? // UI 标记色，如 #1E90FF
  description String?
  sortOrder   Int           @default(0)
  parts       SectionPart[]
  createdAt   DateTime      @default(now())

  @@index([modelKitId])
}

// 部位下的取件项：某板件的某剪口 × 数量
model SectionPart {
  id         String  @id @default(cuid())
  sectionId  String
  section    Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  runnerName String // 板件名，如 A / B1
  gateNo     String // 剪口编号，如 26
  quantity   Int     @default(1)
  sortOrder  Int     @default(0)

  @@index([sectionId])
}
